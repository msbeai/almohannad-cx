---
import '../styles/global.css';
import { SITE, T, type Lang } from '../site';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** path of the same page in the other language, for the toggle + hreflang */
  altPath?: string;
  /** false when altPath is not a true translation (e.g. EN-only articles) */
  altExact?: boolean;
  /** current path for nav highlighting, e.g. "/articles" */
  current?: string;
  ogType?: 'website' | 'article';
  /** extra JSON-LD blocks (e.g. Article schema) */
  schema?: object[];
  /** emit noindex (for backup/recovery pages not meant for Google) */
  noindex?: boolean;
}

const { lang, title, description, altPath, altExact = true, current, ogType = 'website', schema = [], noindex = false } = Astro.props;
const t = T[lang];
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const desc = description ?? (lang === 'ar' ? SITE.descriptionAr : SITE.descriptionEn);
const name = lang === 'ar' ? SITE.nameAr : SITE.nameEn;
const canonical = new URL(Astro.url.pathname, Astro.site);
const altLang = lang === 'ar' ? 'en' : 'ar';
const altUrl = altPath ? new URL(altPath, Astro.site) : undefined;
const homeHref = lang === 'ar' ? '/' : '/en';
const rssHref = lang === 'ar' ? '/rss.xml' : '/en/rss.xml';
const ogImage = new URL('/og-default.png', Astro.site);
const ogLocale = lang === 'ar' ? 'ar_SA' : 'en_US';
const ogLocaleAlt = lang === 'ar' ? 'en_US' : 'ar_SA';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.nameEn,
  alternateName: SITE.nameAr,
  url: Astro.site?.toString(),
  jobTitle: 'Customer Experience Director',
  worksFor: { '@type': 'Organization', name: 'Thmanyah', alternateName: 'ثمانية' },
  sameAs: [SITE.linkedin, SITE.linkedinAuthor],
  knowsAbout: [
    'Customer Experience',
    'تجربة العميل',
    'Marketing Research',
    'الأبحاث التسويقية',
    'Voice of Customer',
    'Customer Journey Mapping',
    'NPS',
  ],
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.nameEn,
  alternateName: [SITE.nameAr, 'almohannad.cx'],
  url: Astro.site?.toString(),
  inLanguage: ['ar', 'en'],
  author: { '@type': 'Person', name: SITE.nameEn },
};
const allSchema = [personSchema, websiteSchema, ...schema];
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    {altUrl && altExact && (
      <>
        <link rel="alternate" hreflang={lang} href={canonical} />
        <link rel="alternate" hreflang={altLang} href={altUrl} />
        <link rel="alternate" hreflang="x-default" href={lang === 'ar' ? canonical : altUrl} />
      </>
    )}
    <link rel="alternate" type="application/rss+xml" title={name} href={rssHref} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="author" content={name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={name} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(allSchema)} />
    <link rel="preload" href="/fonts/thmanyahserifdisplay-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/thmanyahsans-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // set theme before first paint to avoid a flash; falls back to system preference
      (() => {
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
      })();
    </script>
    {SITE.cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${SITE.cfBeaconToken}"}`}
      ></script>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'ar' ? 'تخطَّ إلى المحتوى' : 'Skip to content'}</a>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={homeHref}><img class="brand-avatar" src="/images/avatar.jpg" alt="" width="32" height="32" /><span class="brand-name">almohannad<span class="tld">.cx</span></span></a>
        <button
          class="nav-toggle"
          id="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label={lang === 'ar' ? 'فتح القائمة' : 'Open menu'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path class="nav-toggle-bars" d="M3 6h18M3 12h18M3 18h18"></path>
            <path class="nav-toggle-x" d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
        <nav class="site-nav" id="site-nav" aria-label={lang === 'ar' ? 'التنقل الرئيسي' : 'Main navigation'}>
          {t.nav.map((item) => (
            <a
              href={item.href}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noopener' : undefined}
              aria-current={current === item.href ? 'page' : undefined}
            >{item.label}</a>
          ))}
          <a
            class="nav-search"
            href={lang === 'ar' ? '/search' : '/en/search'}
            aria-label={lang === 'ar' ? 'البحث في الموقع' : 'Search the site'}
            title={lang === 'ar' ? 'بحث' : 'Search'}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m20 20-3.5-3.5"></path>
            </svg>
            <span class="nav-search-label">{lang === 'ar' ? 'بحث' : 'Search'}</span>
          </a>
          <a class="lang-switch" href={altPath ?? (lang === 'ar' ? '/en' : '/')} lang={altLang} dir={altLang === 'ar' ? 'rtl' : 'ltr'}>{t.switchLabel}</a>
          <button
            class="theme-toggle"
            id="theme-toggle"
            type="button"
            aria-label={lang === 'ar' ? 'تبديل الوضع الداكن' : 'Toggle dark mode'}
            title={lang === 'ar' ? 'الوضع الداكن / الفاتح' : 'Dark / light mode'}
          >
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>© {new Date().getFullYear()} {name} — {t.rights}</span>
        <span class="footer-links">
          <a href={SITE.linkedin} rel="me noopener" target="_blank">LinkedIn</a>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <a href={rssHref}>{t.rss}</a>
        </span>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
      // mobile nav toggle
      (() => {
        const btn = document.getElementById('nav-toggle');
        const nav = document.getElementById('site-nav');
        if (!btn || !nav) return;
        const setOpen = (open) => {
          nav.classList.toggle('open', open);
          btn.setAttribute('aria-expanded', String(open));
        };
        btn.addEventListener('click', () => setOpen(!nav.classList.contains('open')));
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });
      })();
    </script>
  </body>
</html>
