---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { SITE, T } from '../../site';
import { getArticles, readingMinutes, excerpt } from '../../lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('ar');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const slug = article.id.replace(/\.md$/, '');
const en = (await getCollection('en')).find((e) => e.id === article.id);
const minutes = readingMinutes(article.body);
const dateStr = article.data.date?.toLocaleDateString('ar-SA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const related = (await getArticles('ar'))
  .filter((a) => a.id !== article.id && a.data.theme === article.data.theme)
  .slice(0, 3);
const shareUrl = `https://almohannad.cx/articles/${slug}`;
const shareText = encodeURIComponent(article.data.title);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  alternativeHeadline: article.data.titleEn,
  inLanguage: 'ar',
  ...(article.data.date && { datePublished: article.data.date.toISOString().slice(0, 10) }),
  author: { '@type': 'Person', name: 'Almohannad Alsbeai', alternateName: 'المهند السبيعي', url: 'https://almohannad.cx' },
  publisher: { '@type': 'Person', name: 'Almohannad Alsbeai' },
  mainEntityOfPage: `https://almohannad.cx/articles/${slug}`,
  image: 'https://almohannad.cx/og-default.png',
  about: article.data.theme === 'cx' ? 'تجربة العميل' : 'الأبحاث التسويقية',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: 'https://almohannad.cx/' },
    { '@type': 'ListItem', position: 2, name: 'المقالات', item: 'https://almohannad.cx/articles' },
    { '@type': 'ListItem', position: 3, name: article.data.title, item: shareUrl },
  ],
};
---

<Base
  lang="ar"
  title={`${article.data.title} — المهند السبيعي`}
  description={excerpt(article.body, 160)}
  altPath={en ? `/en/articles/${slug}` : '/en/articles'}
  altExact={!!en}
  ogType="article"
  schema={[articleSchema, breadcrumbSchema]}
>
  <article class="wrap" data-pagefind-body>
    <nav class="breadcrumb" aria-label="مسار التنقل">
      <a href="/">الرئيسية</a>
      <span class="bc-sep" aria-hidden="true">/</span>
      <a href="/articles">المقالات</a>
    </nav>
    <header class="article-head">
      <h1>{article.data.title}</h1>
      <div class="meta">
        {dateStr && <span>{T.ar.publishedOn} {dateStr}</span>}
        <span>{minutes} {T.ar.minutes}</span>
      </div>
    </header>

    <div class="prose measure">
      <Content />
    </div>

    <footer class="article-foot measure">
      {article.data.linkedin && (
        <a class="article-orig" href={article.data.linkedin} target="_blank" rel="noopener">{T.ar.onLinkedIn} ↗</a>
      )}
      <div class="article-share">
        <span class="share-label">شارك المقال:</span>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener">لينكدإن</a>
        <a href={`https://x.com/intent/tweet?url=${shareUrl}&text=${shareText}`} target="_blank" rel="noopener">إكس</a>
        <a href={`https://wa.me/?text=${shareText}%20${shareUrl}`} target="_blank" rel="noopener">واتساب</a>
      </div>
    </footer>
  </article>

  {related.length > 0 && (
    <section class="related wrap" aria-label="مقالات ذات صلة">
      <h2>اقرأ أيضًا</h2>
      <div class="card-grid">
        {related.map((a) => (
          <ArticleCard
            lang="ar"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        ))}
      </div>
    </section>
  )}

  <aside class="follow-cta wrap">
    <p>أكتب بانتظام عن تجربة العميل والأبحاث التسويقية. للمزيد:</p>
    <div class="follow-actions">
      <a class="btn btn-solid" href={SITE.linkedin} target="_blank" rel="noopener">تابعني على لينكدإن</a>
      <a class="btn btn-ghost" href="https://blog.almohannad.cx" target="_blank" rel="noopener">المدونة</a>
      <a class="btn btn-ghost" href="/articles">كل المقالات</a>
    </div>
  </aside>
</Base>
