---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getArticles, excerpt } from '../../lib/articles';

const all = await getArticles('ar'); // already newest-first
const isoOf = (a) => (a.data.date ? a.data.date.toISOString().slice(0, 10) : '');
---

<Base lang="ar" title="المقالات — المهند السبيعي" altPath="/en/articles" current="/articles">
  <div class="wrap">
    <header class="page-head">
      <h1>المقالات</h1>
      <p>
        {all.length} مقالًا نُشر أغلبها أصلًا على لينكدإن، مرتّبةً من الأحدث إلى الأقدم.
      </p>
    </header>

    <nav class="filter-row" aria-label="ترتيب حسب تاريخ النشر" id="sort">
      <span class="filter-label">الترتيب:</span>
      <a href="#" data-sort="new" aria-current="true">الأحدث أولًا</a>
      <a href="#" data-sort="old">الأقدم أولًا</a>
    </nav>

    <div class="card-grid" style="margin-bottom: 4rem">
      {all.map((a) => (
        <div data-date={isoOf(a)} style="display: contents">
          <ArticleCard
            lang="ar"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        </div>
      ))}
    </div>
  </div>

  <script>
    // client-side sort toggle; default order (newest-first) is already server-rendered.
    const grid = document.querySelector<HTMLElement>('.card-grid');
    const items = grid ? [...grid.children] as HTMLElement[] : [];
    const sortBy = (dir: string) => {
      const sorted = [...items].sort((a, b) => {
        const da = a.dataset.date ?? '', db = b.dataset.date ?? '';
        if (!da && !db) return 0;
        if (!da) return 1; // undated always last
        if (!db) return -1;
        return dir === 'old' ? da.localeCompare(db) : db.localeCompare(da);
      });
      sorted.forEach((el) => grid!.appendChild(el));
    };
    document.querySelectorAll<HTMLAnchorElement>('#sort a').forEach((a) =>
      a.addEventListener('click', (e) => {
        e.preventDefault();
        document.querySelectorAll('#sort a').forEach((x) => x.setAttribute('aria-current', String(x === a)));
        sortBy(a.dataset.sort ?? 'new');
      })
    );
  </script>
</Base>
