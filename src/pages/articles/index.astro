---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getArticles, excerpt } from '../../lib/articles';

const all = await getArticles('ar');
const years = [...new Set(all.map((a) => a.data.date?.getFullYear()).filter(Boolean))].sort((a, b) => b - a);
const yearOf = (a) => (a.data.date ? String(a.data.date.getFullYear()) : 'none');
const countIn = (y) => all.filter((a) => a.data.date?.getFullYear() === y).length;
const ar = (n) => n.toLocaleString('ar-EG', { useGrouping: false });
---

<Base lang="ar" title="المقالات — المهند السبيعي" altPath="/en/articles" current="/articles">
  <div class="wrap">
    <header class="page-head">
      <h1>المقالات</h1>
      <p>
        {all.length} مقالًا نُشر أغلبها أصلًا على لينكدإن. تصفّحها كلها أو اختر سنة النشر.
      </p>
    </header>

    <nav class="filter-row" aria-label="تصفية حسب سنة النشر" id="filters">
      <a href="/articles" data-year="all" aria-current="true">الكل ({ar(all.length)})</a>
      {years.map((y) => (
        <a href={`/articles?year=${y}`} data-year={String(y)}>{ar(y)} ({ar(countIn(y))})</a>
      ))}
    </nav>

    <div class="card-grid" style="margin-bottom: 4rem">
      {all.map((a) => (
        <div data-year={yearOf(a)} style="display: contents">
          <ArticleCard
            lang="ar"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        </div>
      ))}
    </div>
  </div>

  <script>
    // client-side year filter (static site, no reload needed)
    const apply = () => {
      const year = new URLSearchParams(location.search).get('year') ?? 'all';
      document.querySelectorAll<HTMLElement>('[data-year]').forEach((el) => {
        if (el.closest('#filters')) {
          el.setAttribute('aria-current', String(el.dataset.year === year));
        } else {
          el.style.display = year === 'all' || el.dataset.year === year ? 'contents' : 'none';
        }
      });
    };
    document.querySelectorAll('#filters a').forEach((a) =>
      a.addEventListener('click', (e) => {
        e.preventDefault();
        history.pushState({}, '', (a as HTMLAnchorElement).href);
        apply();
      })
    );
    window.addEventListener('popstate', apply);
    apply();
  </script>
</Base>
