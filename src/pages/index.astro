---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../site';
import { getArticles, excerpt } from '../lib/articles';

const articles = await getArticles('ar');
const featured = articles.slice(0, 6);
---

<Base lang="ar" title={`${SITE.nameAr} — ${SITE.taglineAr}`} altPath="/en" current="/">
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-text">
        <p class="kicker">تجربة العميل · الأبحاث التسويقية · الكتابة</p>
        <h1>المهند السبيعي</h1>
        <p class="lede">
          قائد تجربة عملاء، مؤلف ومتحدث. أمضيت أكثر من ٢٠ عامًا في الأبحاث التسويقية وتجربة
          العميل، وأكتب بالعربية عمّا أتعلمه: قصص من الواقع، وأدوات تُستخدم لا تُؤطَّر، ورأي
          صريح في ممارسات المهنة — {articles.length} مقالًا حتى الآن، والقادم أكثر.
        </p>
        <div class="hero-actions">
          <a class="btn btn-solid" href="/articles">تصفّح المقالات</a>
          <a class="btn btn-ghost" href="https://blog.almohannad.cx" target="_blank" rel="noopener">المدونة</a>
        </div>
      </div>
      <div class="hero-figure">
        <img src="/images/almohannad-hero.jpg" alt="المهند السبيعي" width="760" height="1163" loading="eager" />
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="wrap stats-grid">
      <div class="stat"><span class="stat-num">+٢٠</span><span class="stat-label">عامًا في تجربة العميل والأبحاث</span></div>
      <div class="stat"><span class="stat-num">٥</span><span class="stat-label">كتب منشورة</span></div>
      <div class="stat"><span class="stat-num">٦</span><span class="stat-label">حوارات بودكاست</span></div>
      <div class="stat"><span class="stat-num">{articles.length.toLocaleString('ar-EG')}</span><span class="stat-label">مقالًا</span></div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>مقالات مختارة</h2>
        <a class="more" href="/articles">كل المقالات ←</a>
      </div>
      <div class="card-grid">
        {featured.map((a) => (
          <ArticleCard
            lang="ar"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>الكتب والبودكاست</h2>
      </div>
      <div class="card-grid">
        <a class="card" href="/books">
          <div class="card-body">
          <span class="meta"><span class="tag">الكتب</span></span>
          <h3>ما نشرته من كتب</h3>
          <p>سبعة إصدارات بين تجربة العميل والأبحاث التسويقية وأعمالٍ أدبيّة — تصفّحها هنا.</p>
        </div>
        </a>
        <a class="card" href="/podcasts">
          <div class="card-body">
          <span class="meta"><span class="tag">البودكاست</span></span>
          <h3>حوارات شاركت فيها</h3>
          <p>لقاءات وحلقات بودكاست شاركت فيها ضيفًا، معظمها على يوتيوب — شاهدها هنا.</p>
        </div>
        </a>
      </div>
    </div>
  </section>
</Base>
