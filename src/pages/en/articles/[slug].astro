---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { THEMES, T } from '../../../site';
import { readingMinutes, excerpt } from '../../../lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('en');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const slug = article.id.replace(/\.md$/, '');
const ar = (await getCollection('ar')).find((e) => e.id === article.id);
const minutes = readingMinutes(article.body);
const dateStr = article.data.date?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  alternativeHeadline: article.data.titleAr,
  inLanguage: 'en',
  ...(article.data.date && { datePublished: article.data.date.toISOString().slice(0, 10) }),
  author: { '@type': 'Person', name: 'Almohannad Alsbeai', alternateName: 'المهند السبيعي', url: 'https://almohannad.cx' },
  publisher: { '@type': 'Person', name: 'Almohannad Alsbeai' },
  mainEntityOfPage: `https://almohannad.cx/en/articles/${slug}`,
  image: 'https://almohannad.cx/og-default.png',
  about: article.data.theme === 'cx' ? 'Customer Experience' : 'Marketing Research',
};
---

<Base
  lang="en"
  title={`${article.data.title} — Almohannad Alsbeai`}
  description={excerpt(article.body, 160)}
  altPath={ar ? `/articles/${slug}` : '/articles'}
  altExact={!!ar}
  ogType="article"
  schema={[articleSchema]}
>
  <article class="wrap">
    <header class="article-head">
      <span class="tag">{THEMES[article.data.theme].en}</span>
      <h1>{article.data.title}</h1>
      <div class="meta">
        {dateStr && <span>{T.en.publishedOn} {dateStr}</span>}
        <span>{minutes} {T.en.minutes}</span>
        <span>Translated from the Arabic original</span>
      </div>
    </header>

    <div class="prose measure">
      <Content />
    </div>

    <footer class="article-foot measure">
      {article.data.linkedin && (
        <a href={article.data.linkedin} target="_blank" rel="noopener">{T.en.onLinkedIn} ↗</a>
      )}
      <a href="/en/articles">← All articles</a>
    </footer>
  </article>
</Base>
