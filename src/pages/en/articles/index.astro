---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getArticles, excerpt } from '../../../lib/articles';

const all = await getArticles('en'); // already newest-first
const isoOf = (a) => (a.data.date ? a.data.date.toISOString().slice(0, 10) : '');
---

<Base lang="en" title="Articles — Almohannad Alsbeai" altPath="/articles" current="/en/articles">
  <div class="wrap">
    <header class="page-head">
      <h1>Articles</h1>
      <p>
        {all.length} articles, most originally published in Arabic on LinkedIn and translated to
        English, newest first.
      </p>
    </header>

    <nav class="filter-row" aria-label="Sort by publication date" id="sort">
      <span class="filter-label">Sort:</span>
      <a href="#" data-sort="new" aria-current="true">Newest first</a>
      <a href="#" data-sort="old">Oldest first</a>
    </nav>

    <div class="card-grid" style="margin-bottom: 4rem">
      {all.map((a) => (
        <div data-date={isoOf(a)} style="display: contents">
          <ArticleCard
            lang="en"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        </div>
      ))}
    </div>
  </div>

  <script>
    const grid = document.querySelector<HTMLElement>('.card-grid');
    const items = grid ? [...grid.children] as HTMLElement[] : [];
    const sortBy = (dir: string) => {
      const sorted = [...items].sort((a, b) => {
        const da = a.dataset.date ?? '', db = b.dataset.date ?? '';
        if (!da && !db) return 0;
        if (!da) return 1; // undated always last
        if (!db) return -1;
        return dir === 'old' ? da.localeCompare(db) : db.localeCompare(da);
      });
      sorted.forEach((el) => grid!.appendChild(el));
    };
    document.querySelectorAll<HTMLAnchorElement>('#sort a').forEach((a) =>
      a.addEventListener('click', (e) => {
        e.preventDefault();
        document.querySelectorAll('#sort a').forEach((x) => x.setAttribute('aria-current', String(x === a)));
        sortBy(a.dataset.sort ?? 'new');
      })
    );
  </script>
</Base>
