---
import Base from '../../../layouts/Base.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';
---

<Base lang="en" title="Newsletter — Almohannad Alsbeai" altPath="/newsletter" current="/en/newsletter">
  <div class="wrap">
    <header class="page-head">
      <h1>The newsletter</h1>
      <p>
        An email whenever I publish something new: an article on customer experience or
        marketing research, a story from the field, or a book summary worth your time. No
        spam, no marketing blasts — unsubscribe anytime.
      </p>
    </header>

    <NewsletterForm
      lang="en"
      heading="Subscribe now"
      text="Leave your email and be the first to read new work."
    />

    <div class="prose measure" style="margin-inline: 0; padding-bottom: 4rem">
      <h2>What you'll get</h2>
      <ul>
        <li>New articles on customer experience and marketing research.</li>
        <li>Stories from day-to-day practice inside organizations — not translated theory.</li>
        <li>Tools and book takeaways that save you the long way around.</li>
      </ul>
    </div>
  </div>
</Base>
