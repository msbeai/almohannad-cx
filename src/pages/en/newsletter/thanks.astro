  <div class="wrap">
    <div class="empty-state" style="margin-block: 6rem">
      <div class="mark">Welcome</div>
      <p style="font-size: 1.15rem; color: var(--ink)">
        You're subscribed — new writing will reach your inbox as soon as it's published.
      </p>
      <p style="margin-top: 1.5rem">
        <a class="btn btn-solid" href="/en/articles">Start reading</a>
      </p>
    </div>
  </div>
</Base>
