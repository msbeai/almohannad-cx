---
import Base from '../../layouts/Base.astro';
import booksData from '../../data/books.json';

interface Book {
  titleAr: string;
  titleEn?: string;
  year?: string;
  descriptionEn?: string;
  link?: string;
  cover?: string;
}
const books = (booksData.books ?? []) as Book[];
---

<Base lang="en" title="Books — Almohannad Alsbeai" altPath="/books" current="/en/books">
  <div class="wrap">
    <header class="page-head">
      <h1>Books</h1>
      <p>My published titles on customer experience and marketing research.</p>
    </header>

    {books.length === 0 ? (
      <div class="empty-state">
        <div class="mark">Soon</div>
        <p>This section is being prepared — published books will appear here shortly.</p>
      </div>
    ) : (
      <div class="card-grid" style="margin-bottom: 4rem">
        {books.map((b) => (
          <a class="card" href={b.link} target="_blank" rel="noopener">
            {b.cover && <img src={b.cover} alt={b.titleEn ?? b.titleAr} loading="lazy" />}
            <span class="meta">{b.year && <span>{b.year}</span>}</span>
            <h3>{b.titleEn ?? b.titleAr}</h3>
            {b.descriptionEn && <p>{b.descriptionEn}</p>}
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
