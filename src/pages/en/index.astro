---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { SITE } from '../../site';
import { getArticles, excerpt } from '../../lib/articles';

const articles = await getArticles('en');
const featured = articles.slice(0, 6);
---

<Base lang="en" title={`${SITE.nameEn} — ${SITE.taglineEn}`} altPath="/" current="/en">
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Customer experience · Marketing research · Writing</p>
      <h1>Almohannad Alsbeai</h1>
      <p class="lede">
        Customer experience practitioner and marketing researcher from Saudi Arabia. I've
        spent years in the field and write about what I learn: real stories, tools that get
        used rather than framed, and honest opinions about the practice — {articles.length}
        articles so far, with more to come.
      </p>
      <div class="hero-actions">
        <a class="btn btn-solid" href="/en/articles">Browse articles</a>
        <a class="btn btn-ghost" href="/en/newsletter">Join the newsletter</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>Selected articles</h2>
        <a class="more" href="/en/articles">All articles →</a>
      </div>
      <div class="card-grid">
        {featured.map((a) => (
          <ArticleCard
            lang="en"
            slug={a.id.replace(/\.md$/, '')}
            title={a.data.title}
            theme={a.data.theme}
            date={a.data.date}
            excerpt={excerpt(a.body)}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>Books & podcasts</h2>
      </div>
      <div class="card-grid">
        <a class="card" href="/en/books">
          <span class="meta"><span class="tag">Books</span></span>
          <h3>Published books</h3>
          <p>My published titles — this section is being prepared and will be live soon.</p>
        </a>
        <a class="card" href="/en/podcasts">
          <span class="meta"><span class="tag">Podcasts</span></span>
          <h3>Podcast appearances</h3>
          <p>Conversations and episodes I joined as a guest, mostly on YouTube — coming soon.</p>
        </a>
      </div>
    </div>
  </section>

  <div class="wrap">
    <NewsletterForm lang="en" />
  </div>
</Base>
