---
import Base from '../layouts/Base.astro';
import booksData from '../data/books.json';

interface Book {
  titleAr: string;
  titleEn?: string;
  year?: string;
  descriptionAr?: string;
  link?: string;
  cover?: string;
  file?: string;
}
const books = (booksData.books ?? []) as Book[];
---

<Base lang="ar" title="الكتب — المهند السبيعي" altPath="/en/books" current="/books">
  <div class="wrap">
    <header class="page-head">
      <h1>الكتب</h1>
      <p>إصداراتي المنشورة — في تجربة العميل والأبحاث التسويقية، وأعمالٌ أدبيّة.</p>
    </header>

    {books.length === 0 ? (
      <div class="empty-state">
        <div class="mark">قريبًا</div>
        <p>هذا القسم قيد التجهيز — ستجد هنا الكتب المنشورة قريبًا بإذن الله.</p>
      </div>
    ) : (
      <div class="book-grid">
        {books.map((b) => (
          <article class="book-card">
            {b.cover && (
              <div class="book-cover-wrap">
                <img class="book-cover" src={b.cover} alt={`غلاف كتاب ${b.titleAr}`} loading="lazy" />
              </div>
            )}
            <div class="book-meta">{b.year && <span>{b.year}</span>}</div>
            <h3>{b.titleAr}</h3>
            {b.descriptionAr && <p class="book-brief">{b.descriptionAr}</p>}
            {b.file && (
              <a class="book-download" href={b.file} download>تحميل الكتاب (PDF) ↓</a>
            )}
          </article>
        ))}
      </div>
    )}
    <div style="height: 3rem"></div>
  </div>
</Base>

<style>
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 3rem 2.4rem;
    margin-bottom: 2rem;
  }
  .book-card {
    display: flex;
    flex-direction: column;
  }
  .book-cover-wrap {
    perspective: 1200px;
  }
  .book-cover {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.45rem;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.3), 0 3px 8px rgba(0, 0, 0, 0.22);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .book-card:hover .book-cover {
    transform: translateY(-6px);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.38), 0 5px 12px rgba(0, 0, 0, 0.26);
  }
  .book-meta {
    color: var(--ink-faint);
    font-size: 0.85rem;
    margin: 1.1rem 0 0.2rem;
  }
  .book-card h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    line-height: 1.5;
    margin: 0 0 0.5rem;
  }
  .book-brief {
    color: var(--ink-soft);
    font-size: 0.93rem;
    line-height: 1.85;
    margin: 0;
  }
  .book-download {
    align-self: flex-start;
    margin-top: 0.85rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .book-download:hover {
    border-color: var(--ink-faint);
    color: var(--ink);
  }
  @media (max-width: 520px) {
    .book-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.3rem;
    }
    .book-card h3 {
      font-size: 1.05rem;
    }
  }
</style>
