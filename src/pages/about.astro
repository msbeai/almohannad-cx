---
import Base from '../layouts/Base.astro';
import { SITE } from '../site';
---

<Base lang="ar" title="عنّي — المهند السبيعي" altPath="/en/about" current="/about">
  <div class="wrap">
    <div class="deck deck--hang" data-pagefind-body>
      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card fcard--cover">
        <img class="cover-avatar" src="/images/avatar.jpg" alt="المهند السبيعي" width="84" height="84" />
        <h1>ما وراء السيرة</h1>
        <p>بطاقاتٌ قصيرة عن الإنسان خلف العمل — المهند السبيعي.</p>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">١</span>
        <h2>مُسمّى على اسم سيف</h2>
        <div class="fc-term"><span class="term">المُهنَّد</span><span class="pos">[اسم]</span></div>
        <p class="fc-pron">النطق: /المُهَنَّد/</p>
        <p>سيفٌ عالي الجودة مصنوعٌ من الفولاذ الهندي، اشتُهر بقوّته وحدّته وإتقان صناعته.</p>
        <p><strong>باختصار:</strong> رمزٌ للقوّة والدقّة والشرف في الثقافة العربية؛ ارتبط في الموروث بالشجاعة والفرسان، وورد كنايةً شعريّةً في الأدب العربي الكلاسيكي.</p>
        <p class="fcard-note">نادِني «مهنّد» وأسقِط «الـ»، فهو أبسط. وإن آثرتَ التقليد، فـ«أبو رند» تفي بالغرض.</p>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٢</span>
        <h2>لا صخب، بل رسوخ</h2>
        <p class="fcard-lead">أُقدّر النظام والمسؤولية والقوّة الهادئة.</p>
        <ul>
          <li>أُقدّم الوضوح والثبات وإتقان العمل على مجرّد إنجازه بسرعة.</li>
          <li>أزدهر في بيئاتٍ مبنيّةٍ على الثقة، يُقدَّر فيها الاحترام والاعتمادية.</li>
          <li>أُفكّر مليًّا قبل أن أتكلّم — متروٍّ لا سلبيّ.</li>
          <li>أميل إلى الانطوائية، لكنّني أهتمّ كثيرًا بالتعاون ذي المعنى.</li>
          <li>أقود بالأصالة والهدوء والتعاطف، لا بعلوّ الصوت.</li>
        </ul>
        <p class="fcard-note">باختصار: أنا الشخص الذي يمكنك الاعتماد عليه؛ حاضرٌ بهدوء، وموثوقٌ على الدوام.</p>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٣</span>
        <h2>قِيَمي، بوصلتي</h2>
        <ol>
          <li><strong>المسؤولية:</strong> أتحمّل أفعالي وأثرها، ويستطيع الآخرون الاعتماد عليّ.</li>
          <li><strong>التعاطف:</strong> أُنصت لأفهم، وأقود بوعيٍ بالمشاعر.</li>
          <li><strong>النزاهة:</strong> أفعل الصواب وأتواصل بصدق.</li>
          <li><strong>الانضباط الذاتي:</strong> أُقدّر ضبط النفس والنظام والنموّ المقصود.</li>
          <li><strong>الحكمة:</strong> أسعى لقراراتٍ متأنّية وأتعلّم من التجربة.</li>
          <li><strong>الاستقلالية:</strong> أُفكّر باستقلال، وأبقى متّزنًا وصادقًا مع نفسي.</li>
          <li><strong>المعنى:</strong> أبحث عن عملٍ ذي معنى، لا عن النتائج وحدها.</li>
        </ol>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٤</span>
        <h2>حياةٌ خارج العمل</h2>
        <p>بينما أنا منظَّمٌ ومركِّزٌ في العمل، أقود في البيت بقلبي.</p>
        <p><strong>عائلتي هي سببي وفرحي وسندي الأكبر.</strong></p>
        <p>تُذكّرني أنّ العمل مهمّ، لكنّ الحبّ هو كلّ شيء. 🤍</p>
        <p>أبٌ فخورٌ لثلاثة: رند (٢٠١٠)، وورد (٢٠١٢)، وزيد (٢٠١٨).</p>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٥</span>
        <h2>وقودُ وقتي الحر</h2>
        <p class="fcard-lead">أؤمن أنّ ما نحبّه في أوقات فراغنا يقول عنّا بقدر ما تقوله مسمّياتنا الوظيفية. وهذه أشيائي:</p>
        <ul class="plain">
          <li>📚 القراءة — طريقي لأعيش حيواتٍ لا تُحصى.</li>
          <li>📝 الكتابة — لأرتّب أفكاري وأبلغ الوضوح.</li>
          <li>🍳 الطبخ — لأستجمّ، ولأُظهر اهتمامي بالآخرين.</li>
          <li>🏓 كرة الطاولة — ماهرٌ فيها: يدٌ سريعةٌ ولفّاتٌ ماكرة.</li>
          <li>🎾 البادل — ما زلت مبتدئًا، لكنّي أستمتع بالتعلّم.</li>
          <li>☕ القهوة — تحضيرها طقسٌ أحبّه.</li>
        </ul>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٦</span>
        <h2>رحلة، لا وجهة</h2>
        <p class="fcard-lead">على مدى ١٨ عامًا عملتُ في ٩ شركات — صقلت كلٌّ منها نموّي بطريقتها.</p>
        <p>💡 أبقى ما دمتُ أُضيف قيمةً أو أكتسبها؛ وحين يتعذّر الأمران، أمضي.</p>
        <ol class="companies">
          <li><strong>فيدكس:</strong> لوجستيات وشحن عالمي، تشتهر بالسرعة والاعتمادية.</li>
          <li><strong>سينوفيت:</strong> وكالة أبحاثٍ تسويقيّةٍ عالمية، استحوذت عليها إبسوس لاحقًا.</li>
          <li><strong>إبسوس:</strong> من كبرى شركات أبحاث السوق عالميًّا.</li>
          <li><strong>علم:</strong> شركة شبه حكومية للحلول الرقمية والحكومة الإلكترونية.</li>
          <li><strong>مصرف الراجحي:</strong> أكبر بنكٍ إسلامي؛ خدماتٌ مصرفيّةٌ للأفراد والشركات.</li>
          <li><strong>الصادرات السعودية:</strong> هيئةٌ حكوميّةٌ لتنمية الصادرات غير النفطية.</li>
          <li><strong>شورمر:</strong> أكبر سلسلة مطاعم شاورما في السعودية.</li>
          <li><strong>Tweeq:</strong> شركة تقنية مالية (ترخيص EMI)، استحوذت عليها تابي.</li>
          <li><strong>رواء:</strong> شركة SaaS سريعة النمو للمخزون ونقاط البيع والمحاسبة.</li>
        </ol>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card">
        <span class="fcard-num" aria-hidden="true">٧</span>
        <h2>لأرتقي، لا لأُقيّم</h2>
        <p class="fcard-lead">حين أنضمّ إلى فريق، أحضر لأرتقي لا لأُقيّم — لأساعده على التميّز عبر تجربة عميلٍ استثنائية. وهكذا أعمل:</p>
        <ol>
          <li>أُقيّم نضج تجربة العميل وأبني خارطة طريقٍ عمليّةٍ للتحسين.</li>
          <li>أُنصت وأسأل لاكتشاف الفرص — لا لأنتقد أحدًا.</li>
          <li>أُطوّر المنهجيات المناسبة لقياس ما يهمّ فعلًا.</li>
          <li>أُعيد تصميم رحلات العميل حتى نفي بما وعدنا به.</li>
          <li>أُعزّز الثقافة حتى تصبح التجربة الاستثنائية هي المعيار.</li>
        </ol>
        <p class="fcard-note"><strong>وعدي:</strong> أبني على ما هو قائمٌ بالفعل، ودوري أن نرفع السقف معًا — بانفتاحٍ واحترامٍ وشفافية.</p>
      </article></div>

      <div class="hang"><span class="hang-peg" aria-hidden="true"></span><article class="fcard hang-card fcard--cover">
        <p>للتواصل، تجدني على <a href={SITE.linkedin} target="_blank" rel="noopener">لينكدإن</a> أو راسلني على <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</p>
      </article></div>
    </div>
    <div style="height: 2rem"></div>
  </div>

  <script>
    (() => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      const cards = Array.from(document.querySelectorAll('.hang-card'));
      if (!cards.length) return;
      const MAX = 0.34, STIFF = 0.02, DAMP = 0.9;
      const state = cards.map((card) => ({ card, wrap: card.parentElement, angle: 0, vel: 0, dragging: false, px: 0, py: 0 }));
      let running = false;
      const apply = (s) => { s.card.style.transform = s.angle ? `rotate(${s.angle}rad)` : ''; };
      const frame = () => {
        let active = false;
        for (const s of state) {
          if (s.dragging) { active = true; continue; }
          if (Math.abs(s.angle) > 0.0006 || Math.abs(s.vel) > 0.0006) {
            s.vel += -STIFF * s.angle;
            s.vel *= DAMP;
            s.angle += s.vel;
            if (s.angle > MAX) { s.angle = MAX; s.vel *= -0.4; }
            else if (s.angle < -MAX) { s.angle = -MAX; s.vel *= -0.4; }
            apply(s); active = true;
          } else if (s.angle !== 0) { s.angle = 0; s.vel = 0; apply(s); }
        }
        running = active;
        if (active) requestAnimationFrame(frame);
      };
      const kick = () => { if (!running) { running = true; requestAnimationFrame(frame); } };
      for (const s of state) {
        s.card.addEventListener('pointerdown', (e) => {
          if (reduce.matches || e.target.closest('a')) return;
          if (e.pointerType === 'touch' && !e.target.closest('.hang-peg')) return;
          const r = s.wrap.getBoundingClientRect();
          s.px = r.left + r.width / 2; s.py = r.top;
          s.dragging = true;
          try { s.card.setPointerCapture(e.pointerId); } catch (_) {}
          s.card.classList.add('is-grabbing');
          e.preventDefault();
        });
        s.card.addEventListener('pointermove', (e) => {
          if (!s.dragging) return;
          let a = Math.atan2(e.clientX - s.px, Math.max(1, e.clientY - s.py));
          if (a > MAX) a = MAX; else if (a < -MAX) a = -MAX;
          s.vel = a - s.angle; s.angle = a; apply(s);
        });
        const up = (e) => {
          if (!s.dragging) return;
          s.dragging = false; s.card.classList.remove('is-grabbing');
          try { s.card.releasePointerCapture(e.pointerId); } catch (_) {}
          kick();
        };
        s.card.addEventListener('pointerup', up);
        s.card.addEventListener('pointercancel', up);
      }
      if (!reduce.matches) {
        state.forEach((s, i) => { s.angle = (i % 2 ? -1 : 1) * 0.14; s.vel = (i % 2 ? 1 : -1) * 0.004; apply(s); });
        kick();
      }
    })();
  </script>
</Base>
