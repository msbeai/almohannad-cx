---
/**
 * Newsletter subscription form.
 * Currently captures subscribers via Netlify Forms (form name: "newsletter").
 * When an external newsletter tool is chosen, point `action` at its endpoint
 * (or replace the form markup with the provider's embed) — the journey
 * (box → form → /newsletter/thanks) stays the same.
 */
import { type Lang } from '../site';

interface Props {
  lang: Lang;
  heading?: string;
  text?: string;
}

const { lang } = Astro.props;
const heading =
  Astro.props.heading ?? (lang === 'ar' ? 'النشرة البريدية' : 'The newsletter');
const text =
  Astro.props.text ??
  (lang === 'ar'
    ? 'مقال جديد في تجربة العميل يصلك إلى بريدك — قصص وتجارب من الميدان، لا قوالب جاهزة ولا كلامًا استشاريًا.'
    : 'New customer-experience writing in your inbox — field stories and practice, no recycled frameworks.');
const thanks = lang === 'ar' ? '/newsletter/thanks' : '/en/newsletter/thanks';
const placeholder = lang === 'ar' ? 'بريدك الإلكتروني' : 'Your email';
const cta = lang === 'ar' ? 'اشترك' : 'Subscribe';
---

<div class="newsletter-box">
  <h2>{heading}</h2>
  <p>{text}</p>
  <form
    class="newsletter-form"
    name="newsletter"
    method="POST"
    action={thanks}
    data-netlify="true"
    netlify-honeypot="bot-field"
  >
    <input type="hidden" name="form-name" value="newsletter" />
    <input type="hidden" name="lang" value={lang} />
    <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
    <input type="email" name="email" required placeholder={placeholder} dir="ltr" />
    <button type="submit">{cta}</button>
  </form>
</div>
