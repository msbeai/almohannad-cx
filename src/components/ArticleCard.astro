---
import type { Lang } from '../site';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  theme: 'cx' | 'research';
  excerpt?: string;
  date?: Date;
}

const { lang, slug, title, theme, excerpt, date } = Astro.props;
const href = lang === 'ar' ? `/articles/${slug}` : `/en/articles/${slug}`;
const cover = `/images/covers/${slug}-${lang}.png`;
const dateStr = date?.toLocaleDateString(lang === 'ar' ? 'ar-SA' : 'en-US', {
  year: 'numeric',
  month: 'long',
});
---

<a class="card" href={href}>
  <img class="card-cover" src={cover} alt="" loading="lazy" decoding="async" width="1200" height="630" />
  <div class="card-body">
    <span class="meta">
      {dateStr && <span>{dateStr}</span>}
    </span>
    <h3>{title}</h3>
    {excerpt && <p>{excerpt}</p>}
  </div>
</a>
